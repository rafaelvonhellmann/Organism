{
  "name": "organism",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node node_modules/tsx/dist/cli.mjs --experimental-sqlite scripts/start-daemon.ts",
    "morning-brief": "node node_modules/tsx/dist/cli.mjs --experimental-sqlite scripts/morning-brief.ts",
    "dashboard": "node node_modules/tsx/dist/cli.mjs --experimental-sqlite packages/dashboard/src/server.ts",
    "dashboard-v2": "pnpm --filter dashboard-v2 dev",
    "ensure-services": "node node_modules/tsx/dist/cli.mjs --experimental-sqlite scripts/ensure-services.ts",
    "health-check": "node node_modules/tsx/dist/cli.mjs --experimental-sqlite scripts/health-check.ts",
    "shadow-promote": "node node_modules/tsx/dist/cli.mjs --experimental-sqlite scripts/shadow-promote.ts",
    "migrate": "node node_modules/tsx/dist/cli.mjs --experimental-sqlite scripts/migrate.ts",
    "smoke-test": "node node_modules/tsx/dist/cli.mjs --experimental-sqlite scripts/smoke-test.ts",
    "certify": "node node_modules/tsx/dist/cli.mjs --experimental-sqlite scripts/smoke-test.ts",
    "test:core": "node node_modules/tsx/dist/cli.mjs --experimental-sqlite --test packages/core/src/*.test.ts",
    "test:dashboard-auth": "node node_modules/tsx/dist/cli.mjs --test packages/dashboard-v2/src/lib/auth.test.ts",
    "smoke:dashboard-auth": "node node_modules/tsx/dist/cli.mjs scripts/dashboard-auth-smoke.ts",
    "certify:full": "npm run test:core && npm run test:dashboard-auth && npm run smoke-test",
    "medium-lane-test": "node node_modules/tsx/dist/cli.mjs --experimental-sqlite scripts/medium-lane-test.ts",
    "review-synapse": "node node_modules/tsx/dist/cli.mjs --experimental-sqlite scripts/review-synapse.ts",
    "stixdb": "python packages/stixdb/start.py",
    "organism": "node node_modules/tsx/dist/cli.mjs --experimental-sqlite scripts/cli.ts",
    "sync-turso": "node node_modules/tsx/dist/cli.mjs --experimental-sqlite scripts/sync-turso.ts",
    "execute": "node node_modules/tsx/dist/cli.mjs --experimental-sqlite scripts/execute-actions.ts",
    "clear-stuck": "node node_modules/tsx/dist/cli.mjs --experimental-sqlite scripts/clear-stuck-tasks.ts",
    "sync-agentation": "node node_modules/tsx/dist/cli.mjs --experimental-sqlite scripts/cli.ts sync-agentation",
    "agentation": "node node_modules/tsx/dist/cli.mjs packages/agentation/server.ts",
    "desktop": "cd packages/desktop && npx electron .",
    "desktop:build": "cd packages/desktop && npx electron-builder"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@libsql/client": "^0.17.2",
    "@playwright/mcp": "^0.0.70",
    "playwright": "^1.60.0-alpha-1774999321000"
  }
