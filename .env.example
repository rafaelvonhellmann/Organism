# Organism — Required Environment Variables
# Copy to .env and fill in values. Never commit .env.

# LLM Providers
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
ORGANISM_MODEL_BACKEND=codex-first
ORGANISM_CODE_EXECUTOR=codex-first

# Budget
SYSTEM_DAILY_CAP_USD=50
# Per-agent overrides (optional — defaults in packages/core/src/budget.ts)
# BUDGET_CEO=1.50
# BUDGET_ENGINEERING=4.00
# BUDGET_QUALITY_GUARDIAN=25.00

# Dashboard
DASHBOARD_PORT=7391

# PraisonAI MCP Sidecar
MCP_SIDECAR_HOST=localhost
MCP_SIDECAR_PORT=8765

# Telegram (G4 gate notifications)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Agentation — UI annotation/review sidecar (optional pilot)
AGENTATION_ENABLED=false
AGENTATION_SERVER_URL=http://localhost:4100
AGENTATION_AUTH_TOKEN=
AGENTATION_TIMEOUT_MS=5000
