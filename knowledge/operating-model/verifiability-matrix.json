{
  "version": 1,
  "updatedAt": "2026-05-01",
  "source": "Karpathy-inspired jaggedness model: capability depends on domain verifiability and whether the task is on the frontier-lab reinforcement-learning rails.",
  "classes": {
    "HIGH": {
      "description": "Outputs can be checked cheaply with deterministic tools, tests, logs, schemas, or reproducible commands.",
      "runtimePosture": "Act autonomously within task scope, run deterministic checks, include verification output, and auto-ship only when the risk lane permits."
    },
    "MEDIUM": {
      "description": "Outputs can be partially checked with evidence, acceptance criteria, known heuristics, or user feedback.",
      "runtimePosture": "Act autonomously but surface assumptions, evidence, tradeoffs, and acceptance criteria."
    },
    "LOW": {
      "description": "Outputs rely on judgement over ambiguous or external reality: legal, medical, strategy, market timing, brand risk.",
      "runtimePosture": "Require citations, playbook mapping, uncertainty, and review gates. Prefer proposals over direct mutation."
    },
    "NON_DELEGABLE": {
      "description": "Final decisions that require Rafael, a qualified professional, or explicit business approval.",
      "runtimePosture": "Do not decide or apply. Prepare the decision packet and request approval."
    }
  },
  "defaultProfile": {
    "verifiability": "MEDIUM",
    "onRailsSignals": [
      "task references code, tests, logs, schemas, known framework docs, or supplied source evidence"
    ],
    "offRoadSignals": [
      "task asks for legal reliance, medical correctness, market prediction, major spend, credentials, brand stance, or external-world claims without sources"
    ],
    "mustVerify": [
      "state assumptions",
      "cite available evidence",
      "name missing evidence",
      "separate proposed actions from applied actions"
    ],
    "approvalRequiredFor": [
      "irreversible actions",
      "external communications",
      "money movement",
      "legal or clinical reliance",
      "scope expansion"
    ]
  },
