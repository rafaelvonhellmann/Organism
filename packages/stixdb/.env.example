# StixDB Configuration for Organism
STIXDB_LLM_PROVIDER=anthropic
STIXDB_ANTHROPIC_API_KEY=sk-ant-...
STIXDB_STORAGE_MODE=kuzu
STIXDB_KUZU_DB_DIR=../../state/stixdb
STIXDB_VECTOR_BACKEND=numpy
STIXDB_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
STIXDB_EMBEDDING_DIMENSION=384
STIXDB_API_PORT=4020
STIXDB_API_KEY=organism-stixdb-local
STIXDB_LOG_LEVEL=info

# Agent consolidation
STIXDB_AGENT_CYCLE_INTERVAL=30.0
STIXDB_AGENT_CONSOLIDATION_THRESHOLD=0.88
STIXDB_AGENT_DECAY_HALF_LIFE=48
STIXDB_AGENT_PRUNE_THRESHOLD=0.05
